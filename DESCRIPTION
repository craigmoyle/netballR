Package: netballR
Title: Download and Tidy Netball Match Statistics
Version: 0.4.0
Authors@R: c(
    person("Steve", "Lane", email = "lane.s@unimelb.edu.au", role = "aut"),
    person("Craig", "Moyle", email = "craig.moyle@mantelgroup.com.au",
           role = c("aut", "cre"))
